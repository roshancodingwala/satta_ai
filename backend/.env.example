# ── SattvaAI Backend Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your real values.

# Google Gemini API Key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# ChromaDB persistence directory (relative to backend/)
CHROMA_PERSIST_DIR=./data/chroma_db

# Path to the Indian Wisdom PDF for RAG ingestion
WISDOM_PDF_PATH=./data/wisdom.pdf

# RAG retrieval — number of context chunks returned
RAG_TOP_K=4

# Set to "true" to enable verbose logging
DEBUG=false
